{
  "name": "clothing-store",
  "version": "2.0.0",
  "description": "BlazeUp clothing store — PostgreSQL + JWT refactor",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "db:init": "psql $DATABASE_URL -f db/schema.sql",
    "db:migrate": "node db/migrate.js",
    "db:migrate-v2": "psql $DATABASE_URL -f db/migrate_v2.sql"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
